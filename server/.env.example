# ── Database ───────────────────────────────────────────────────────────────────
# Dev (SQLite — no server needed):
DATABASE_URL="file:./prisma/dev.db"

# Production (PostgreSQL — also change provider in prisma/schema.prisma):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/parthsaarthi?schema=public&sslmode=require"

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="8h"

# Google OAuth client ID (Google Cloud Console → Credentials → OAuth 2.0 Client ID)
# Must also set VITE_GOOGLE_CLIENT_ID in client/.env for the frontend button
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"

# ── Dev mode ───────────────────────────────────────────────────────────────────
# Uncomment ONLY in local development. Absence of this var = production Google OAuth.
# AUTH_MODE=dev

# Redirect ALL outgoing emails to this address during development.
# REMOVE THIS LINE entirely in production — real users need their own emails.
# DEV_EMAIL_OVERRIDE=your@email.com

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=4000
# Set to the exact origin your frontend is served from (no trailing slash)
CLIENT_ORIGIN="http://localhost:3000"
# Production example:
# CLIENT_ORIGIN="https://parthsaarthi.iiml.ac.in"

# ── SMTP (Email) ───────────────────────────────────────────────────────────────
# Without these, emails are logged to console only (dev behaviour).
# Option A — Gmail with App Password (500 emails/day free):
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
# Generate at: myaccount.google.com → Security → App Passwords (requires 2FA)
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM=Parthsaarthi <your@gmail.com>

# Option B — Brevo/Sendinblue (300 emails/day free, better deliverability):
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@email.com
# SMTP_PASS=your-brevo-api-key
# SMTP_FROM=Parthsaarthi <noreply@yourdomain.com>
