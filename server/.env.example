# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (SQLite, no server needed):
DATABASE_URL="file:./prisma/dev.db"

# Production (PostgreSQL — swap provider in schema.prisma too):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/parthsaarthi?schema=public"

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="8h"

# Google OAuth client ID (from Google Cloud Console → Credentials)
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
# CORS origin — the URL your frontend is served from
CLIENT_ORIGIN="http://localhost:3000"
